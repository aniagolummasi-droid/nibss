<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Triakwheel Bank</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&family=Space+Grotesk:wght@600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/triakwheel.css">
</head>
<body>
  <main class="auth-shell transfer-shell">
    <section class="auth-card transfer-card">
      <a class="nav-link" href="/customer/dashboard">Back to dashboard</a>
      <p class="eyebrow">Move money</p>
      <h1>Send a clean, trackable transfer.</h1>

      <% if (account) { %>
        <div class="mini-balance">
          <span>From <%= account.accountNumber %></span>
          <strong><%= formatCurrency(account.balance) %></strong>
        </div>
      <% } else { %>
        <div class="alert alert-error">Create an account before making a transfer.</div>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/account/payments/transfer" method="POST" class="stack-form">
        <label>
          <span>Recipient account number</span>
          <input id="recipientAccountNumber" type="text" name="toAccountNumber" value="<%= form.toAccountNumber || '' %>" placeholder="1000123456" required>
        </label>

        <div id="recipientLookup" class="lookup-panel" hidden></div>

        <label>
          <span>Amount</span>
          <input type="number" name="amount" value="<%= form.amount || '' %>" min="1" step="0.01" placeholder="5000" required>
        </label>

        <label>
          <span>Bank code</span>
          <input id="recipientBankCode" type="text" name="bankCode" value="<%= form.bankCode || '' %>" placeholder="<%= defaultBankCode %>">
        </label>

        <label>
          <span>Narration</span>
          <textarea name="narration" rows="3" placeholder="Transfer narration"><%= form.narration || '' %></textarea>
        </label>

        <button class="submit-button" type="submit" <%= account ? '' : 'disabled' %>>Send transfer</button>
      </form>
    </section>
  </main>

  <script>
    const accountInput = document.querySelector('#recipientAccountNumber');
    const bankCodeInput = document.querySelector('#recipientBankCode');
    const lookupPanel = document.querySelector('#recipientLookup');
    let lookupTimer;
    let lastLookupKey = '';
    let lookupController;

    const setLookupPanel = (message, state = 'info') => {
      lookupPanel.hidden = false;
      lookupPanel.className = `lookup-panel lookup-panel-${state}`;
      lookupPanel.textContent = message;
    };

    const clearLookupPanel = () => {
      lookupPanel.hidden = true;
      lookupPanel.textContent = '';
      lookupPanel.className = 'lookup-panel';
    };

    const lookupRecipient = async () => {
      const accountNumber = accountInput.value.replace(/\D/g, '');
      const bankCode = bankCodeInput.value.trim();
      const lookupKey = `${accountNumber}:${bankCode}`;

      if (accountNumber.length < 10 || lookupKey === lastLookupKey) {
        if (accountNumber.length < 10) {
          clearLookupPanel();
        }
        return;
      }

      lastLookupKey = lookupKey;
      setLookupPanel('Checking recipient details...', 'info');

      if (lookupController) {
        lookupController.abort();
      }

      lookupController = new AbortController();

      try {
        const response = await fetch('/account/payments/name-enquiry', {
          method: 'POST',
          signal: lookupController.signal,
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify({ accountNumber, bankCode })
        });
        const result = await response.json();

        if (!response.ok) {
          setLookupPanel(result.error || 'Recipient could not be verified', 'error');
          return;
        }

        if (result.bankCode) {
          bankCodeInput.value = result.bankCode;
        }

        const bankLabel = [result.bankName, result.bankCode].filter(Boolean).join(' - ');
        const details = bankLabel ? `${result.name} (${bankLabel})` : result.name;
        setLookupPanel(`Recipient found: ${details}`, 'success');
      } catch (error) {
        if (error.name === 'AbortError') {
          return;
        }

        setLookupPanel('Unable to check recipient right now', 'error');
      }
    };

    accountInput.addEventListener('input', () => {
      clearTimeout(lookupTimer);
      lookupTimer = setTimeout(lookupRecipient, 500);
    });

    bankCodeInput.addEventListener('input', () => {
      clearTimeout(lookupTimer);
      lookupTimer = setTimeout(lookupRecipient, 500);
    });

    if (accountInput.value.replace(/\D/g, '').length >= 10) {
      lookupRecipient();
    }
  </script>
</body>
</html>
